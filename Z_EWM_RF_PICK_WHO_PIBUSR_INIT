FUNCTION Z_EWM_RF_PICK_WHO_PIBUSR_INIT.
*"----------------------------------------------------------------------
*"*"Local Interface:
*"  CHANGING
*"     REFERENCE(RESOURCE) TYPE  /SCWM/S_RSRC OPTIONAL
*"     REFERENCE(ZT_WHO_SCREEN) TYPE  ZTTRF_ZPISYS_WHO_SCREEN OPTIONAL
*"     REFERENCE(S_WHO_SCREEN) TYPE  ZSRF_ZPISYS_WHO_SCREEN OPTIONAL
*"     REFERENCE(NESTPT) TYPE  /SCWM/S_RF_NESTED OPTIONAL
*"----------------------------------------------------------------------

 DATA: ls_rsrc_tmp  TYPE /scwm/rsrc.
*        ls_recov     TYPE ztewm_rf_recov,
*        lv_work_who  TYPE /scwm/de_who.
*
*  " Kontrollo recovery
*  GET PARAMETER ID '/SCWM/WORK_WHO' FIELD lv_work_who.
*
*  IF lv_work_who IS NOT INITIAL.
*    CALL FUNCTION '/SCWM/RSRC_RESOURCE_MEMORY'
*      EXPORTING iv_uname = sy-uname
*      CHANGING  cs_rsrc  = ls_rsrc_tmp.
*
*    SELECT SINGLE *
*      FROM ztewm_rf_recov
*      INTO ls_recov
*      WHERE lgnum  = ls_rsrc_tmp-lgnum
*        AND uname  = sy-uname
*        AND ltrans = 'ZPIQUE'.
*
*    IF sy-subrc = 0 AND ls_recov-last_step IS NOT INITIAL.
*      CASE ls_recov-last_step.
*        WHEN 'ZPICK4'.
*          /scwm/cl_rf_bll_srvc=>set_prmod( '1' ).
*          /scwm/cl_rf_bll_srvc=>set_fcode( 'ZGOPR' ).
*          RETURN.
*        WHEN 'ZPICK5'.
*          /scwm/cl_rf_bll_srvc=>set_prmod( '1' ).
*          /scwm/cl_rf_bll_srvc=>set_fcode( 'ZCONF' ).
*          RETURN.
*        WHEN 'ZPICK6'.
*          /scwm/cl_rf_bll_srvc=>set_prmod( '1' ).
*          /scwm/cl_rf_bll_srvc=>set_fcode( 'INIT' ).
*          RETURN.
*      ENDCASE.
*    ENDIF.
*  ENDIF.

*  DATA: ls_rsrc_tmp TYPE /scwm/rsrc.
  CONSTANTS: lc_euro_pallet_m3 TYPE p DECIMALS 1 VALUE '1.3'.
/scwm/cl_rf_bll_srvc=>set_flg_stack( iv_flg_stack = ' ' ).
/scwm/cl_rf_bll_srvc=>init_call_stack_optimizer( ).

  CALL FUNCTION '/SCWM/RSRC_RESOURCE_MEMORY'
    EXPORTING iv_uname = sy-uname
    CHANGING  cs_rsrc  = ls_rsrc_tmp.

* THIS IS THE KEY - registers screen parameters with framework
  PERFORM init_screen
    CHANGING zt_who_screen
             s_who_screen.

  REFRESH zt_who_screen.
  CLEAR s_who_screen.

  CHECK gv_selected_who IS NOT INITIAL.

* Build single entry directly - no get_who_list needed
  APPEND INITIAL LINE TO zt_who_screen
    ASSIGNING FIELD-SYMBOL(<ls_scr>).

  <ls_scr>-who = gv_selected_who.

  SELECT SINGLE rdocid
    FROM /scwm/ordim_o
    WHERE lgnum = @ls_rsrc_tmp-lgnum
      AND who   = @gv_selected_who
    INTO @DATA(lv_rdocid).

  IF lv_rdocid IS NOT INITIAL.

    SELECT SINGLE docno FROM /scdl/db_proch_o
      WHERE docid = @lv_rdocid
      INTO @<ls_scr>-pdo.

    SELECT SINGLE partyno FROM /scdl/db_bploc
      WHERE docid      = @lv_rdocid
        AND party_role = 'STPRT'
      INTO @<ls_scr>-partyno.

    IF <ls_scr>-partyno IS NOT INITIAL.
      SELECT SINGLE name_org1 FROM but000
        WHERE partner = @<ls_scr>-partyno
        INTO @<ls_scr>-name_org1.
    ENDIF.

  ENDIF.

  SELECT COUNT(*) AS r_stops, SUM( vsola ) AS c_packages
    FROM /scwm/ordim_o
    WHERE lgnum     = @ls_rsrc_tmp-lgnum
      AND who       = @gv_selected_who
      AND sloc_type = 'B'
    INTO @DATA(ls_agg).

  <ls_scr>-r_stops    = ls_agg-r_stops.
  <ls_scr>-c_packages = ls_agg-c_packages.

  SELECT SUM( volum ) FROM /scwm/ordim_o
    WHERE lgnum = @ls_rsrc_tmp-lgnum
      AND who   = @gv_selected_who
    INTO @DATA(lv_volum).

  IF lv_volum > 0.
    <ls_scr>-disp_pallet = ceil( lv_volum / lc_euro_pallet_m3 ).
  ENDIF.

  s_who_screen = <ls_scr>.

  CALL METHOD /scwm/cl_rf_bll_srvc=>set_scr_tabname
    EXPORTING iv_scr_tabname = 'ZTTRF_ZPISYS_WHO_SCREEN'.

  CALL METHOD /scwm/cl_rf_bll_srvc=>set_line
    EXPORTING iv_line = 1.

  CLEAR gv_selected_who.

ENDFUNCTION.
