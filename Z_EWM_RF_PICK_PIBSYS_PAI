*          EXPORTING
*            iv_flg_continue_flow = 'X'
*            iv_msgid             = '/SCWM/RF_EN'
*            iv_msgno             = '056' ).
*        /scwm/cl_rf_bll_srvc=>set_prmod(
*          EXPORTING
*            iv_prmod    = /scwm/cl_rf_bll_srvc=>c_prmod_background
*            iv_ovr_cust = 'X' ).
*        /scwm/cl_rf_bll_srvc=>set_fcode( /scwm/cl_rf_bll_srvc=>c_fcode_leave ).
*        RETURN.
*      ELSE.

**        *       Clear stack to prevent back navigation issues
*        /scwm/cl_rf_bll_srvc=>set_call_stack_optimizer(
*          iv_step = 'ZPI2' ).
*        /scwm/cl_rf_bll_srvc=>set_call_stack_optimizer(
